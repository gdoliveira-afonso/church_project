# ============================================================
# Variáveis de Ambiente do Projeto
# Copie este arquivo para .env e preencha os valores.
# ============================================================

# OBRIGATÓRIO — Chave secreta para assinar os tokens JWT.
# Deve ser uma string longa e aleatória. Gere com:
#   openssl rand -hex 32
JWT_SECRET=coloque-aqui-um-secret-longo-e-aleatorio

# Porta em que o servidor backend vai escutar.
PORT=4000

# --- Banco de Dados ---
# SQLite (padrão, simples — ideal para instâncias únicas)
DATABASE_URL="file:./data/database.db"

# PostgreSQL (recomendado para produção):
# 1. Altere o provider em server/prisma/schema.prisma para "postgresql"
# 2. Defina a DATABASE_URL abaixo:
# DATABASE_URL="postgresql://user:password@localhost:5432/church_crm"

# Diretório onde os uploads de arquivos serão armazenados.
UPLOAD_DIR=./uploads
